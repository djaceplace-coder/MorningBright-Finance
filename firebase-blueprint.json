{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account registration and permission status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "isFrozen": { "type": "boolean" },
        "isSuspended": { "type": "boolean" },
        "biometricsEnabled": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "firstName", "lastName", "email", "isVerified", "isAdmin", "isFrozen", "isSuspended"]
    },
    "UserBalance": {
      "title": "UserBalance",
      "description": "User central funds balances",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "checking": { "type": "number" },
        "savings": { "type": "number" },
        "updatedAt": { "type": "string" }
      },
      "required": ["uid", "checking", "savings", "updatedAt"]
    },
    "BankTransaction": {
      "title": "BankTransaction",
      "description": "Credit and debit ledger records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string" },
        "category": { "type": "string" },
        "merchant": { "type": "string" },
        "recipientEmail": { "type": "string" },
        "senderEmail": { "type": "string" },
        "createdAt": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "userId", "amount", "type", "category", "merchant", "createdAt", "status"]
    },
    "VirtualCard": {
      "title": "VirtualCard",
      "description": "Sleek contactless digital card configuration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "cardholderName": { "type": "string" },
        "cardNumber": { "type": "string" },
        "expiryDate": { "type": "string" },
        "cvv": { "type": "string" },
        "isFrozen": { "type": "boolean" },
        "spendingLimit": { "type": "number" },
        "spentThisMonth": { "type": "number" },
        "cardType": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "cardholderName", "cardNumber", "expiryDate", "cvv", "isFrozen", "spendingLimit", "spentThisMonth", "cardType"]
    },
    "SavingsGoal": {
      "title": "SavingsGoal",
      "description": "User financial savings target parameters",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "autoSaveEnabled": { "type": "boolean" },
        "autoSavePercentage": { "type": "number" },
        "color": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "title", "targetAmount", "currentAmount", "autoSaveEnabled"]
    },
    "BankNotification": {
      "title": "BankNotification",
      "description": "Realtime notification triggers and state",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "isRead": { "type": "boolean" },
        "type": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "title", "message", "isRead", "type", "createdAt"]
    },
    "UserProfileSettings": {
      "title": "UserProfileSettings",
      "description": "User custom device and app configurations",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "faceIdEnabled": { "type": "boolean" },
        "webAuthnConfigured": { "type": "boolean" },
        "pushNotifications": { "type": "boolean" },
        "emailStatements": { "type": "boolean" },
        "twoFactorEnabled": { "type": "boolean" }
      },
      "required": ["uid", "faceIdEnabled", "webAuthnConfigured", "pushNotifications", "emailStatements", "twoFactorEnabled"]
    },
    "AdminLog": {
      "title": "AdminLog",
      "description": "Immutable security audits for admin portal adjustments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adminId": { "type": "string" },
        "adminEmail": { "type": "string" },
        "action": { "type": "string" },
        "targetUserId": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "adminId", "adminEmail", "action", "targetUserId", "details", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Stores user registration definitions"
    },
    "/balances/{uid}": {
      "schema": "UserBalance",
      "description": "User currency balances"
    },
    "/transactions/{transactionId}": {
      "schema": "BankTransaction",
      "description": "User ledger audit log"
    },
    "/cards/{cardId}": {
      "schema": "VirtualCard",
      "description": "Virtual touch debit card rules"
    },
    "/savings/{goalId}": {
      "schema": "SavingsGoal",
      "description": "Goal-saving structures"
    },
    "/notifications/{notificationId}": {
      "schema": "BankNotification",
      "description": "Account event push notifications"
    },
    "/settings/{uid}": {
      "schema": "UserProfileSettings",
      "description": "User-level toggle configurations"
    },
    "/admin_logs/{logId}": {
      "schema": "AdminLog",
      "description": "Chronicle of system changes performed by admins"
    }
  }
}
