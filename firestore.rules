rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Safety Constants & Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Bootstrap user email adereraadenike@gmail.com as Admin
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "adereraadenike@gmail.com"
      );
    }

    function remainsUnchanged(field) {
      return !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }

    // Document Validation
    function isValidUserProfile(data) {
      return data.uid is string &&
             data.firstName is string && data.firstName.size() <= 100 &&
             data.lastName is string && data.lastName.size() <= 100 &&
             data.email is string && data.email.size() <= 150 &&
             data.isVerified is bool &&
             data.isAdmin is bool &&
             data.isFrozen is bool &&
             data.isSuspended is bool;
    }

    // --- COLLECTION RULES ---

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid && 
                      isValidUserProfile(request.resource.data) && 
                      request.resource.data.isAdmin == false && 
                      request.resource.data.isFrozen == false && 
                      request.resource.data.isSuspended == false;
      allow update: if isSignedIn() && (
        // Self-updates (Cannot modify critical flags)
        (request.auth.uid == uid && isValidUserProfile(request.resource.data) &&
         request.resource.data.isAdmin == resource.data.isAdmin &&
         request.resource.data.isFrozen == resource.data.isFrozen &&
         request.resource.data.isSuspended == resource.data.isSuspended &&
         request.resource.data.uid == resource.data.uid) ||
        // Administrative changes
        (isAdmin() && isValidUserProfile(request.resource.data) && request.resource.data.uid == resource.data.uid)
      );
    }

    match /balances/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (
        (request.auth.uid == uid && remainsUnchanged('uid')) ||
        isAdmin()
      );
    }

    match /transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /cards/{cardId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (
        (resource.data.userId == request.auth.uid && remainsUnchanged('userId')) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /savings/{goalId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (
        (resource.data.userId == request.auth.uid && remainsUnchanged('userId')) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isSignedIn() && (
        (resource.data.userId == request.auth.uid && request.resource.data.isRead is bool) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /settings/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    match /admin_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false; // Immutable ledger
    }

    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false; // System-level lock, edited out-of-band only
    }
  }
}
